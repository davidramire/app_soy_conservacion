// =============================================================================
// Prisma Schema — Soy Conservación
// Base de datos: PostgreSQL + PostGIS
// SRID: 4326 (WGS 84) — sistema de coordenadas geográficas estándar global
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Usuarios
// ---------------------------------------------------------------------------

model Usuario {
  idUsuario         Int                      @id @default(autoincrement()) @map("id_usuario")
  username          String                   @unique
  fechaRegistro     DateTime                 @default(now()) @map("fecha_registro") @db.Timestamptz
  observaciones     Observacion[]
  observacionesInat InaturalistObservacion[]

  @@map("usuarios")
}

// ---------------------------------------------------------------------------
// Catálogo taxonómico
// ---------------------------------------------------------------------------

model GrupoTaxonomico {
  idGrupo           Int                      @id @default(autoincrement()) @map("id_grupo")
  nombre            String                   @unique
  especies          Especie[]
  observacionesInat InaturalistObservacion[]

  @@map("grupo_taxonomico")
}

model Especie {
  idEspecie         Int                      @id @default(autoincrement()) @map("id_especie")
  nombreCientifico  String                   @unique @map("nombre_cientifico")
  grupoTaxonomicoId Int                      @map("grupo_taxonomico")
  grupoTaxonomico   GrupoTaxonomico          @relation(fields: [grupoTaxonomicoId], references: [idGrupo], onDelete: Restrict, onUpdate: Cascade)
  observaciones     Observacion[]
  observacionesInat InaturalistObservacion[]

  @@index([grupoTaxonomicoId], map: "especies_grupo_taxonomico_idx")
  @@map("especies")
}

// ---------------------------------------------------------------------------
// Fuentes de datos
// ---------------------------------------------------------------------------

model Fuente {
  idFuente          Int                      @id @default(autoincrement()) @map("id_fuente")
  nombre            String                   @unique
  observaciones     Observacion[]
  observacionesInat InaturalistObservacion[]

  @@map("fuente")
}

// ---------------------------------------------------------------------------
// Observaciones — Drive / ODK
// La columna geom es geometry(Point, 4326): punto geográfico WGS 84.
// Se sincroniza automáticamente con latitud/longitud via trigger PostgreSQL.
// Prisma la declara como Unsupported porque no tiene soporte nativo de PostGIS,
// pero el tipo real en la DB es geometry(Point, 4326) con SRID correcto.
// ---------------------------------------------------------------------------

model Observacion {
  idObservacion Int                                   @id @default(autoincrement()) @map("id_observacion")
  usuarioId     Int                                   @map("id_usuario")
  especieId     Int                                   @map("id_especie")
  instanceId    String                                @unique @map("instance_id")
  fecha         DateTime                              @map("fecha") @db.Timestamptz
  foto          String?
  audio         String?
  latitud       Float?
  longitud      Float?
  /// Punto geográfico WGS 84 (EPSG:4326). Tipo real: geometry(Point, 4326).
  /// Sincronizado automáticamente con latitud/longitud via trigger PostgreSQL.
  /// Usar ST_Intersects / ST_DWithin en queries raw para máxima precisión.
  geom          Unsupported("geometry(Point, 4326)")?
  altitude      Float?
  accuracy      Float?
  fuenteId      Int                                   @map("id_fuente")
  usuario       Usuario                               @relation(fields: [usuarioId], references: [idUsuario], onDelete: Restrict, onUpdate: Cascade)
  especie       Especie                               @relation(fields: [especieId], references: [idEspecie], onDelete: Restrict, onUpdate: Cascade)
  fuente        Fuente                                @relation(fields: [fuenteId], references: [idFuente], onDelete: Restrict, onUpdate: Cascade)
  // Índice GIST espacial definido en la migración SQL (no soportado por Prisma DSL).
  // Nombre: observaciones_geom_gist_idx

  @@index([usuarioId], map: "observaciones_id_usuario_idx")
  @@index([especieId], map: "observaciones_id_especie_idx")
  @@index([fuenteId], map: "observaciones_id_fuente_idx")
  @@index([fecha], map: "observaciones_fecha_idx")
  @@index([latitud, longitud], map: "observaciones_lat_lng_idx")
  @@index([fecha, latitud, longitud], map: "observaciones_fecha_lat_lng_idx")
  @@map("observaciones")
}

// ---------------------------------------------------------------------------
// Observaciones — iNaturalist
// Misma lógica de geom que la tabla de observaciones Drive.
// ---------------------------------------------------------------------------

model InaturalistObservacion {
  idInaturalistObservacion Int                                   @id @default(autoincrement()) @map("id_inaturalist_observacion")
  usuarioId                Int                                   @map("id_usuario")
  especieId                Int                                   @map("id_especie")
  inaturalistId            String                                @unique @map("inaturalist_id")
  fecha                    DateTime                              @map("fecha") @db.Timestamptz
  foto                     String?
  audio                    String?
  latitud                  Float?
  longitud                 Float?
  /// Punto geográfico WGS 84 (EPSG:4326). Tipo real: geometry(Point, 4326).
  /// Sincronizado automáticamente con latitud/longitud via trigger PostgreSQL.
  /// Usar ST_Intersects / ST_DWithin en queries raw para máxima precisión.
  geom                     Unsupported("geometry(Point, 4326)")?
  accuracy                 Float?
  urlInaturalist           String?                               @map("url_inaturalist")
  qualityGrade             String?                               @map("quality_grade")
  license                  String?                               @map("license")
  grupoTaxonomicoId        Int                                   @map("id_grupo")
  fuenteId                 Int                                   @map("id_fuente")
  usuario                  Usuario                               @relation(fields: [usuarioId], references: [idUsuario], onDelete: Restrict, onUpdate: Cascade)
  especie                  Especie                               @relation(fields: [especieId], references: [idEspecie], onDelete: Restrict, onUpdate: Cascade)
  grupoTaxonomico          GrupoTaxonomico                       @relation(fields: [grupoTaxonomicoId], references: [idGrupo], onDelete: Restrict, onUpdate: Cascade)
  fuente                   Fuente                                @relation(fields: [fuenteId], references: [idFuente], onDelete: Restrict, onUpdate: Cascade)
  // Índice GIST espacial definido en la migración SQL (no soportado por Prisma DSL).
  // Nombre: inaturalist_observaciones_geom_gist_idx

  @@index([usuarioId], map: "inaturalist_observaciones_id_usuario_idx")
  @@index([especieId], map: "inaturalist_observaciones_id_especie_idx")
  @@index([grupoTaxonomicoId], map: "inaturalist_observaciones_id_grupo_idx")
  @@index([fuenteId], map: "inaturalist_observaciones_id_fuente_idx")
  @@index([fecha], map: "inaturalist_observaciones_fecha_idx")
  @@index([latitud, longitud], map: "inaturalist_observaciones_lat_lng_idx")
  @@index([fecha, latitud, longitud], map: "inaturalist_observaciones_fecha_lat_lng_idx")
  @@map("inaturalist_observaciones")
}
